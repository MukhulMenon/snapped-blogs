<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Snapped Blogs</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <style>
        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
        }

        .container {
            text-align: center;
        }

        .title {
            color: #fff;
            font-size: 2.5em;
            margin-bottom: 30px;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.3);
        }

        .cards {
            display: flex;
            gap: 25px;
            justify-content: center;
            flex-wrap: wrap;
        }

        .card {
            background: #f5f5f5;
            padding: 40px;
            width: 280px;
            border-radius: 16px;
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.2);
            text-align: center;
            transition: 0.3s ease;
            cursor: pointer;
        }

        .card:hover {
            transform: translateY(-6px);
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.25);
        }

        .card h2 {
            margin-bottom: 15px;
            color: #222;
        }

        .card p {
            font-size: 0.95rem;
            color: #555;
            margin-bottom: 20px;
        }

        .card a {
            text-decoration: none;
            padding: 10px 18px;
            background: #1e73e8;
            color: white;
            border-radius: 8px;
            font-weight: 600;
            transition: 0.3s ease;
        }

        .card a:hover {
            background: #155ab6;
        }
    </style>
</head>

<body>
    <div class="container">
        <div class="title">Welcome to Snapped Blogs</div>

        <div class="cards">
            <!-- View Blogs Card -->
            <div class="card">
                <h2>📖 View Blogs</h2>
                <p>Browse all published blog posts and explore content.</p>
                <a href="/blog-list">View Blogs</a>
            </div>

            <!-- Create Blog Card -->
            <div class="card">
                <h2>✍️ Create Blog</h2>
                <p>Write and publish a new blog post.</p>
                <a href="/create-blog">Create Blog</a>
            </div>
        </div>
    </div>
</body>
</html>