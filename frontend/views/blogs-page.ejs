<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Snapped Blogs</title>

    <style>
        * {
            box-sizing: border-box;
        }

        ::-webkit-scrollbar {
            display: none;
        }

        body {
            margin: 0;
            font-family: Arial, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            padding: 40px 30px;
        }

        h1 {
            text-align: center;
            color: #fff;
            font-size: 2.5rem;
            margin: 10px 0 30px;
            text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.25);
        }

        .grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
            gap: 28px;
            max-width: 1200px;
            margin: 0 auto;
        }

        .card {
            background: #fff;
            border-radius: 14px;
            box-shadow: 0 14px 30px rgba(0, 0, 0, 0.18);
            padding: 26px 26px 22px;
            text-align: center;
            border: 2px solid rgba(0, 0, 0, 0.08);
        }
        .card:hover {
            border-color: rgba(0, 0, 0, 0.15);
            transform: scale(1.03) ;
            transition: all 0.5s ease-in-out;
        }

        .card img {
            width: 300px;
            height: 150px;
            object-fit: contain;
            margin: 10px auto 10px;
            display: block;
        }

        .card img:hover {
            filter: brightness(0.95);
            transform: scale(1.05);
            transition: all 0.3s ease-in-out;
        }

        .title {
            font-size: 2.2rem;
            font-weight: 800;
            margin: 16px 0 14px;
            line-height: 1.1;
            color: #111;
        }

        .summary {
            font-size: 1.25rem;
            line-height: 1.35;
            color: #222;
            margin: 0 auto 18px;
            max-width: 95%;
        }

        .date {
            font-size: 1rem;
            font-style: italic;
            margin: 16px 0 16px;
            color: #111;
        }

        .btn {
            display: inline-block;
            background: #0b66ff;
            color: #fff;
            padding: 12px 26px;
            border-radius: 10px;
            text-decoration: none;
            font-weight: 700;
            font-size: 1.15rem;
            border: 0;
        }

        .btn:hover {
            filter: brightness(0.95);
            transform: translateY(-1px);
        }

        .empty {
            max-width: 900px;
            margin: 0 auto;
            background: rgba(255, 255, 255, 0.9);
            border-radius: 12px;
            padding: 20px;
            text-align: center;
        }

        .note {
            font-size: 0.95rem;
            opacity: 0.85;
            margin-top: 10px;
        }
    </style>
</head>

<body>
    <h1>Welcome to Snapped Blogs</h1>

    <% if (!blogs || blogs.length===0) { %>
        <div class="empty">
            <h2>No blogs found</h2>
            <div class="note">Make sure your backend is running and /api/blog-posts returns data.</div>
        </div>
        <% } else { %>

            <div class="grid">
                <% blogs.forEach((blog)=> { %>
                    <div class="card">
                        
                        <img src="<%= blog.image_url %>" alt="Blog Image"
                            onerror="this.onerror=null; this.src='https://via.placeholder.com/140x70?text=Blog+Image';" />

                        <div class="title">
                            <%= blog.name %>
                        </div>

                        <div class="summary">
                            <%= blog.summary %>
                        </div>

                        <div class="date">
                            <%= blog.date %>
                        </div>
                        <a href="/blog-list/<%= blog.id %>" class="btn">Read More</a>
                    </div>
                    <% }) %>
            </div>

            <% } %>
</body>

</html>