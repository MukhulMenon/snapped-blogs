<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>Snapped Blogs</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <style>
        * {
            box-sizing: border-box;
        }

        body {
            align-items: center;
            margin: 0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
        }

        .card {
            background: #f5f5f5;
            padding: 40px;
            width: 100%;
            max-width: 500px;
            border-radius: 16px;
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.2);
            text-align: center;
        }

        .card h1 {
            margin-bottom: 25px;
            font-size: 2em;
            font-weight: 700;
            color: #222;
        }

        form {
            display: flex;
            flex-direction: column;
            gap: 15px;
            text-align: left;
        }

        label {
            font-weight: 600;
            font-size: 0.9rem;
            margin-bottom: 5px;
            display: block;
        }

        input,
        textarea {
            width: 100%;
            padding: 10px 12px;
            border-radius: 8px;
            border: 1px solid #ccc;
            font-size: 0.95rem;
            transition: 0.2s ease;
        }

        input:focus,
        textarea:focus {
            outline: none;
            border-color: #667eea;
            box-shadow: 0 0 0 2px rgba(102, 126, 234, 0.2);
        }

        textarea {
            resize: vertical;
            min-height: 80px;
        }

        button {
            margin-top: 15px;
            padding: 12px;
            border: none;
            border-radius: 8px;
            background: #1e73e8;
            color: white;
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
            transition: 0.3s ease;
        }

        button:hover {
            background: #155ab6;
            transform: translateY(-2px);
        }

        button:active {
            transform: translateY(0);
        }
    </style>
</head>

<body>
    <div>
        <h1 style="color: #fff; font-size: 2.5em; text-shadow: 2px 2px 4px rgba(0,0,0,0.3); margin-bottom: 20px;">
            Welcome to Snapped Blogs</h1>
        <div class="card">
            <h1>Create Blog Post</h1>

            <form action="/create-blog/submit" method="POST">

                <div>
                    <label for="name">Title</label>
                    <input type="text" id="name" name="name" required>
                </div>

                <div>
                    <label for="summary">Summary</label>
                    <input type="text" id="summary" name="summary" required>
                </div>

                <div>
                    <label for="description">Description</label>
                    <textarea id="description" name="description" required></textarea>
                </div>

                <div>
                    <label for="date">Date</label>
                    <input type="date" id="date" name="date" required>
                </div>

                <div>
                    <label for="image_url">Image URL</label>
                    <input type="url" id="image_url" name="image_url" required>
                </div>

                <button type="submit">Create Blog Post</button>

            </form>
        </div>
    </div>

</body>

</html>